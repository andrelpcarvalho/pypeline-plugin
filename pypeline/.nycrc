{
  "extends": "@istanbuljs/schema",
  "all": true,
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.d.ts", "test/**", "src/index.ts"],
  "reporter": ["lcov", "text", "text-summary"],
  "branches": 70,
  "lines": 70,
  "functions": 70,
  "statements": 70,
  "check-coverage": false,
  "extension": [".ts"]
}
